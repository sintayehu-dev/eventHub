rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own user profile
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Events collection - users can read all events, but only create/update their own
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.organizerId;
      allow update: if request.auth != null && 
        request.auth.uid == resource.data.organizerId;
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.organizerId;
    }
    
    // Tickets collection - for ticket purchases and management
    match /tickets/{ticketId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.userId || 
         request.auth.uid == resource.data.organizerId);
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.userId;
    }
    
    // Staff members collection
    match /staff/{staffId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && 
        (request.auth.uid == staffId || 
         request.auth.uid == resource.data.organizerId);
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.organizerId;
    }
    
    // Staff assignments collection
    match /staff_assignments/{assignmentId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Check-ins collection
    match /check_ins/{checkInId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Event registrations - users can manage their own registrations
    match /events/{eventId}/registrations/{registrationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        request.auth.uid == registrationId;
    }
    
    // Analytics data
    match /analytics/{analyticsId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Reports collection
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Default deny all other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}